# ─────────────────────────────────────────────────────────────
# JokkoLive — Variables d'environnement
# Copier ce fichier en .env.local pour le développement
# ─────────────────────────────────────────────────────────────

# ── Backend API (même serveur que la plateforme meet) ─────────
VITE_API_BASE=https://backjm.unchk.sn

# ── LiveKit ──────────────────────────────────────────────────
VITE_LIVEKIT_WS_URL=wss://livekitjm.unchk.sn
VITE_LIVEKIT_URL=https://livekitjm.unchk.sn

# ── Matrix (si utilisé plus tard) ────────────────────────────
VITE_MATRIX_BASE_URL=https://communication.rtn.sn

# ── Token path (compatibilité plateforme existante) ───────────
VITE_TOKEN_PATH=/api/livekit/token

# ── Debug (désactiver en production) ─────────────────────────
VITE_DEBUG=false